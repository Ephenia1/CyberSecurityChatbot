<Window x:Class="WpfApp2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberSecurity Assistant"
        Height="600" Width="900"
        Background="#1E1E1E"
        KeyDown="Window_KeyDown">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="#2D2D30" Grid.Row="0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15">
                <Image Source="logo.png" Width="40" Height="40" Margin="0,0,10,0"/>
                <TextBlock Text="CyberSecurity Assistant"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- CHAT AREA -->
        <ScrollViewer Grid.Row="1" Name="ChatScroll" VerticalScrollBarVisibility="Auto" Margin="10">
            <StackPanel x:Name="ChatPanel"/>
        </ScrollViewer>

        <!-- INPUT AREA -->
        <Border Grid.Row="2" Background="#2D2D30" Padding="10">
            <DockPanel>
                <TextBox x:Name="UserInput"
                         Height="40"
                         FontSize="14"
                         Background="#1E1E1E"
                         Foreground="White"
                         BorderBrush="#444"
                         Padding="10"
                         DockPanel.Dock="Left"
                         Width="700"/>

                <Button Content="Send"
                        Width="120"
                        Height="40"
                        Margin="10,0,0,0"
                        Background="#007ACC"
                        Foreground="White"
                        BorderBrush="Transparent"
                        Click="SendButton_Click"/>
            </DockPanel>
        </Border>

    </Grid>
</Window>